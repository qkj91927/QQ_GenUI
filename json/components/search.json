{
  "id": "search",
  "name": "搜索框 Search",
  "category": "操作",
  "description": "用于内容检索的搜索输入组件，支持多种交互状态与两种配色（灰底/白底），配色按页面底色反相映射（白页用灰底、灰页用白底）。",
  "spec": "md/SEARCH_COMPONENT_SPEC.md",

  "totalVariants": 12,

  "variants": {
    "A_primary": [
      { "id": "A1", "name": "一级·默认·灰底", "state": "default", "fill": "gray",  "hasBack": false, "inputWidth": 396, "placeholderAlign": "center" },
      { "id": "A2", "name": "一级·激活·灰底", "state": "focused", "fill": "gray",  "hasBack": false, "inputWidth": 350, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true },
      { "id": "A3", "name": "一级·输入·灰底", "state": "typing",  "fill": "gray",  "hasBack": false, "inputWidth": 350, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true, "hasClear": true },
      { "id": "A4", "name": "一级·默认·白底", "state": "default", "fill": "white", "hasBack": false, "inputWidth": 396, "placeholderAlign": "center" },
      { "id": "A5", "name": "一级·激活·白底", "state": "focused", "fill": "white", "hasBack": false, "inputWidth": 350, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true },
      { "id": "A6", "name": "一级·输入·白底", "state": "typing",  "fill": "white", "hasBack": false, "inputWidth": 350, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true, "hasClear": true }
    ],
    "B_secondary": [
      { "id": "B1", "name": "二级·默认·灰底", "state": "default", "fill": "gray",  "hasBack": true, "inputWidth": 328, "placeholderAlign": "left" },
      { "id": "B2", "name": "二级·激活·灰底", "state": "focused", "fill": "gray",  "hasBack": true, "inputWidth": 328, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true },
      { "id": "B3", "name": "二级·输入·灰底", "state": "typing",  "fill": "gray",  "hasBack": true, "inputWidth": 328, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true, "hasClear": true },
      { "id": "B4", "name": "二级·默认·白底", "state": "default", "fill": "white", "hasBack": true, "inputWidth": 328, "placeholderAlign": "left" },
      { "id": "B5", "name": "二级·激活·白底", "state": "focused", "fill": "white", "hasBack": true, "inputWidth": 328, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true },
      { "id": "B6", "name": "二级·输入·白底", "state": "typing",  "fill": "white", "hasBack": true, "inputWidth": 328, "placeholderAlign": "left", "hasCursor": true, "hasCancel": true, "hasClear": true }
    ]
  },

  "layout": {
    "outerContainer": { "width": 428, "height": 36, "padding": "0 16px" },
    "inputBox": {
      "height": 36,
      "radius": 12,
      "fillModes": {
        "gray":  { "token": "fill-tertiary", "value": "rgba(118, 118, 128, 0.12)", "variants": ["A1","A2","A3","B1","B2","B3"] },
        "white": { "token": "bg-bottom",     "value": "#FFFFFF",                    "variants": ["A4","A5","A6","B4","B5","B6"] }
      }
    }
  },

  "pageBgMapping": {
    "rule": "Search 填充色与所在页面底色必须反相映射（白色系 ↔ 非白色系互斥），否则失去视觉分隔",
    "mappings": [
      {
        "pageBgGroup": "白色系页面",
        "pageBgs": [
          { "token": "bg-bottom", "value": "#FFFFFF", "note": "页面默认白底" },
          { "token": "bg-top",    "value": "#FFFFFF", "note": "浮层容器白底" }
        ],
        "searchFill": { "token": "fill-tertiary", "value": "rgba(118,118,128,0.12)" },
        "variants": ["A1","A2","A3","B1","B2","B3"]
      },
      {
        "pageBgGroup": "非白色系页面",
        "pageBgs": [
          { "token": "bg-secondary",    "value": "#F2F2F7", "note": "含 Card/Grouped List/Message 的标准灰底页" },
          { "token": "bg-bottom-brand", "value": "#EFF4FF", "note": "品牌氛围落地页（浅蓝）" },
          { "token": "bg-select",       "value": "#F0F0F2", "note": "AIO 专属灰底页" }
        ],
        "searchFill": { "token": "bg-bottom", "value": "#FFFFFF" },
        "variants": ["A4","A5","A6","B4","B5","B6"]
      }
    ],
    "forbidden": [
      "白色系页面（bg-bottom/bg-top）+ Search fill bg-bottom → 白上白无分隔",
      "非白色系页面（bg-secondary/bg-bottom-brand/bg-select）+ Search fill fill-tertiary → 灰上灰无分隔"
    ]
  },

  "style": {
    "icons": {
      "searchDefault": { "size": 18, "color": { "token": "icon-secondary", "value": "rgba(60,60,67,0.6)" }, "file": "icons/search.svg" },
      "searchTyping":  { "size": 18, "color": { "token": "icon-primary",   "value": "#000000" },             "file": "icons/search.svg" },
      "cursor":        { "width": 1, "height": 18, "color": { "token": "brand-standard", "value": "#0099FF" } },
      "clear":         { "size": 20, "color": { "token": "icon-secondary", "value": "rgba(60,60,67,0.6)" }, "file": "icons/close_input.svg" },
      "backArrow":     { "size": 24, "color": { "token": "icon-primary",   "value": "#000000" },             "file": "icons/chevron_left.svg" }
    },
    "text": {
      "placeholder": { "fontSize": 17, "fontWeight": 400, "color": { "token": "text-tertiary", "value": "rgba(60, 60, 67, 0.3)" } },
      "input":       { "fontSize": 17, "fontWeight": 400, "color": { "token": "text-primary",  "value": "rgba(0, 0, 0, 1.0)" } },
      "cancel":      { "fontSize": 16, "fontWeight": 400, "color": { "token": "text-link",     "value": "#214CA5" } }
    },
    "backArrowLayout": { "containerWidth": 12, "svgSize": 24, "marginLeft": -6, "gapToInput": 12 }
  },

  "interaction": {
    "defaultToFocused": "点击默认态输入框 → 激活态，显示光标和取消按钮",
    "focusedToTyping": "开始输入文字 → 输入态，搜索图标变深色，显示清除按钮",
    "clearAction": "点击清除按钮 → 清空文字，回到激活态",
    "cancelAction": "点击取消按钮 → 回到默认态",
    "backAction": "点击返回箭头 → 返回上一级页面"
  },

  "figmaMapping": {
    "A1": "level=primary,   state=default, align=center, fill=gray",
    "A2": "level=primary,   state=focused, fill=gray",
    "A3": "level=primary,   state=typing,  fill=gray",
    "A4": "level=primary,   state=default, align=center, fill=white",
    "A5": "level=primary,   state=focused, fill=white",
    "A6": "level=primary,   state=typing,  fill=white",
    "B1": "level=secondary, state=default, hasBack=true, fill=gray",
    "B2": "level=secondary, state=focused, hasBack=true, fill=gray",
    "B3": "level=secondary, state=typing,  hasBack=true, fill=gray",
    "B4": "level=secondary, state=default, hasBack=true, fill=white",
    "B5": "level=secondary, state=focused, hasBack=true, fill=white",
    "B6": "level=secondary, state=typing,  hasBack=true, fill=white"
  }
}
